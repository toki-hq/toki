/target
**/target
**/*.rs.bk

# IDE / OS
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.swp

# Logs / env
*.log
.env
.env.*
!.env.example

# Local design / scratch assets — not part of the shipped codebase
design/

# Server-side runtime config (may contain the shared-secret password).
# Each operator drops their own `config.toml` next to the binary or
# points TOKI_CONFIG at one — it must not land in version control.
/config.toml

# Auto-generated self-signed TLS material the server drops next to
# its CWD when no `[tls]` block is configured. The private key is the
# whole point — never commit it.
/tls/

# Coverage artifacts produced by `scripts/coverage.sh`. The HTML
# report and lcov.info are both regeneratable, big, and binary-ish
# — nothing version-controlled should depend on them.
/target/coverage/

# Local working notes — security follow-ups, debugging scratch, etc.
# Tracked locally so future-you keeps the context; not shipped because
# they're often half-thoughts that would rot in public.
/notes/

# Admin panel sqlite store. Created on first boot at the path
# configured by `[admin].db_path` (default `admin.db` next to CWD).
# Contains the seeded admin user's argon2id hash + live session
# tokens — operator-local, must not land in version control.
/admin.db
/admin.db-journal
/admin.db-wal
/admin.db-shm

# Same runtime artifacts, but produced when the server is launched
# with its CWD inside the crate (e.g. `cargo run -p toki-server` from
# crates/server) or with a `TOKI_DATA_DIR` of `./data`. All operator-
# local state — never version-controlled.
/crates/server/admin.db
/crates/server/admin.db-*
/crates/server/tls/
/data/

# Stray runtime artifacts if a server is ever launched from the admin-ui dir.
/crates/server/admin-ui/admin.db
/crates/server/admin-ui/admin.db-*
/crates/server/admin-ui/tls/
